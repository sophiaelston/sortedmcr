  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --yellow: #FFCB00;
      --dark:   #1A1A1A;
      --page:   #F2EFE9;
      --card:   #FFFFFF;
      --muted:  #666;
      --radius: 14px;
      --shadow: 0 4px 20px rgba(0,0,0,0.09);
    }
    html { scroll-behavior: smooth; }
    body { font-family: 'Segoe UI', system-ui, -apple-system, sans-serif; background: var(--page); color: var(--dark); min-height: 100vh; }

    /* HEADER */
    header { background: var(--dark); color: #fff; padding: 0 1.25rem; position: sticky; top: 0; z-index: 100; box-shadow: 0 2px 16px rgba(0,0,0,0.35); }
    .header-inner { max-width: 1100px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; height: 60px; }
    .logo { display: flex; align-items: center; gap: 9px; text-decoration: none; color: #fff; }
    .logo-bee { font-size: 1.5rem; }
    .logo-text { font-size: 1.35rem; font-weight: 900; letter-spacing: -0.5px; }
    .logo-text .y { color: var(--yellow); }
    .back-link { color: rgba(255,255,255,0.6); font-size: 0.78rem; font-weight: 700; text-decoration: none; padding: 6px 14px; border: 1px solid rgba(255,255,255,0.2); border-radius: 20px; transition: all 0.15s; }
    .back-link:hover { color: #fff; border-color: rgba(255,255,255,0.5); }

    /* HERO */
    .hero { background: linear-gradient(140deg, #111 0%, #2a1260 60%, #1a3a5c 100%); color: #fff; padding: 3rem 1.25rem 2.5rem; text-align: center; }
    .hero-eyebrow { font-size: 0.75rem; font-weight: 800; letter-spacing: 2px; text-transform: uppercase; color: var(--yellow); margin-bottom: 0.7rem; }
    .hero h1 { font-size: clamp(1.8rem, 5vw, 2.8rem); font-weight: 900; line-height: 1.15; margin-bottom: 0.75rem; }
    .hero h1 .y { color: var(--yellow); }
    .hero-sub { font-size: 1rem; color: rgba(255,255,255,0.68); max-width: 540px; margin: 0 auto 1.6rem; line-height: 1.6; }
    .hero-cta { display: inline-block; background: var(--yellow); color: var(--dark); font-weight: 900; font-size: 0.95rem; padding: 13px 28px; border-radius: 10px; text-decoration: none; transition: opacity 0.15s; }
    .hero-cta:hover { opacity: 0.88; }

    /* STATS STRIP */
    .stats-strip { background: var(--yellow); padding: 0.9rem 1.25rem; }
    .stats-inner { max-width: 1100px; margin: 0 auto; display: flex; gap: 2rem; justify-content: center; flex-wrap: wrap; }
    .stat { font-size: 0.85rem; font-weight: 800; color: var(--dark); display: flex; align-items: center; gap: 7px; }
    .stat-num { font-size: 1.4rem; font-weight: 900; }

    /* MAIN */
    .wrap { max-width: 1100px; margin: 0 auto; padding: 2.5rem 1.25rem 4rem; }
    .section-title { font-size: 1.5rem; font-weight: 900; margin-bottom: 0.4rem; }
    .section-sub { font-size: 0.9rem; color: var(--muted); margin-bottom: 1.6rem; line-height: 1.5; }

    /* OFFERINGS GRID */
    .offerings-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.2rem; margin-bottom: 3rem; }
    .offering-card { background: var(--card); border-radius: var(--radius); box-shadow: var(--shadow); overflow: hidden; display: flex; flex-direction: column; }
    .offering-stripe { height: 5px; }
    .offering-body { padding: 1.3rem 1.3rem 1rem; flex: 1; }
    .offering-icon { font-size: 1.8rem; margin-bottom: 0.6rem; }
    .offering-title { font-size: 1rem; font-weight: 900; margin-bottom: 0.4rem; }
    .offering-desc { font-size: 0.84rem; color: #444; line-height: 1.55; }
    .offering-footer { padding: 0.75rem 1.3rem 1rem; border-top: 1px solid #f0f0f0; display: flex; align-items: center; justify-content: space-between; }
    .offering-price { font-size: 0.82rem; font-weight: 800; color: var(--dark); }
    .offering-badge { font-size: 0.7rem; font-weight: 800; padding: 3px 9px; border-radius: 20px; background: #E8F5E9; color: #2E7D32; }

    /* WHAT WE WON'T DO */
    .honest-box { background: #fff; border: 1px solid #eee; border-radius: var(--radius); padding: 1.5rem 1.75rem; margin-bottom: 3rem; }
    .honest-box h3 { font-size: 1rem; font-weight: 900; margin-bottom: 0.8rem; }
    .honest-list { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem 1.5rem; }
    .honest-item { font-size: 0.83rem; color: #444; display: flex; align-items: flex-start; gap: 8px; line-height: 1.4; }
    .honest-item .icon { flex-shrink: 0; margin-top: 1px; }
    @media(max-width:560px) { .honest-list { grid-template-columns: 1fr; } }

    /* PROCESS */
    .process-steps { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1rem; margin-bottom: 3rem; }
    .step { background: var(--card); border-radius: var(--radius); padding: 1.2rem; box-shadow: var(--shadow); text-align: center; }
    .step-num { width: 36px; height: 36px; border-radius: 50%; background: var(--dark); color: var(--yellow); font-size: 0.9rem; font-weight: 900; display: flex; align-items: center; justify-content: center; margin: 0 auto 0.7rem; }
    .step-title { font-size: 0.88rem; font-weight: 900; margin-bottom: 0.3rem; }
    .step-desc { font-size: 0.78rem; color: var(--muted); line-height: 1.45; }

    /* CONTACT */
    .contact-section { background: linear-gradient(135deg, #1A1A1A 0%, #2a1260 100%); border-radius: var(--radius); padding: 2.5rem 2rem; color: #fff; text-align: center; }
    .contact-section h2 { font-size: 1.6rem; font-weight: 900; margin-bottom: 0.5rem; }
    .contact-section p { color: rgba(255,255,255,0.65); font-size: 0.9rem; margin-bottom: 1.6rem; line-height: 1.5; max-width: 480px; margin-left: auto; margin-right: auto; }
    .contact-email-btn { display: inline-block; background: var(--yellow); color: var(--dark); font-weight: 900; font-size: 0.95rem; padding: 13px 28px; border-radius: 10px; text-decoration: none; transition: opacity 0.15s; }
    .contact-email-btn:hover { opacity: 0.88; }
    .contact-socials { margin-top: 1.2rem; display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
    .contact-socials a { color: rgba(255,255,255,0.6); font-size: 0.8rem; font-weight: 700; text-decoration: none; }
    .contact-socials a:hover { color: var(--yellow); }

    /* FOOTER */
    footer { background: var(--dark); color: rgba(255,255,255,0.4); text-align: center; padding: 1.5rem 1.25rem; font-size: 0.78rem; line-height: 1.6; }
    footer a { color: var(--yellow); text-decoration: none; }
  </style>
</head>
<body>

<!-- HEADER -->
<header>
  <div class="header-inner">
